{
  "name": "matrix",
  "version": "1.0.2",
  "description": "Desktop application for local database import, indexing, and search.",
  "author": "Matrix Team",
  "type": "module",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "start": "electron .",
    "build": "set ELECTRON_CACHE=.electron-cache&& vite build && electron-builder",
    "test": "node --test tests/main/localdb/*.test.js",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.example.myapp",
    "productName": "Matrix",
    "directories": {
      "output": "dist",
      "buildResources": "src/public"
    },
    "files": [
      "dist/",
      "src/"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "src/public/matrix.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.13.4",
    "electron-log": "^5.4.3",
    "electron-store": "^10.1.0",
    "lucide-vue-next": "^0.536.0",
    "pdf-parse": "^1.1.1",
    "pdfmake": "^0.2.20",
    "pinia": "^3.0.3",
    "vue-router": "^4.5.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "electron": "^38.1.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^7.0.6",
    "vue": "^3.5.18",
    "wait-on": "^8.0.4"
  }
}
